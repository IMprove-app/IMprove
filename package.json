{
  "name": "improve",
  "version": "1.0.1",
  "description": "Daily habit check-in tracker with futuristic UI",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-vite build && electron-builder --win --dir",
    "dist": "electron-vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.improve.app",
    "productName": "IMprove",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "IMprove"
    },
    "publish": {
      "provider": "github",
      "owner": "IMprove-app",
      "repo": "IMprove"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "recharts": "^3.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
